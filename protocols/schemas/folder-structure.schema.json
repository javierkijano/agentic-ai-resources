{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agentic AI Folder Structure Contract",
  "description": "Define qué carpetas son obligatorias en cada dominio funcional.",
  "type": "object",
  "properties": {
    "domain": { "type": "string", "enum": ["skill", "workflow", "workspace"] },
    "required_folders": {
      "type": "array",
      "items": { "type": "string" }
    },
    "required_files": {
      "type": "array",
      "items": { "type": "string" }
    }
  },
  "required": ["domain", "required_folders", "required_files"]
}
